pipeline {
    agent any
    triggers {
        githubPush()
    }
    stages {
        stage('Code Checkout') {
            steps {
                echo 'New code pushed to GitHub by Priya Agrawal!'
                echo 'Webhook triggered this pipeline automatically!'
            }
        }
        stage('Build') {
            steps {
                echo 'Building CI/CD Pipeline Performance Benchmarker...'
                sleep 3
            }
        }
        stage('Test') {
            steps {
                echo 'Running validation tests...'
                sleep 2
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deployment complete!'
                echo 'Dashboard available at localhost:8501'
            }
        }
    }
    post {
        success {
            echo 'CI/CD Pipeline completed successfully!'
        }
    }
}