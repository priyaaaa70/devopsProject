pipeline {
    agent any

    triggers {
        githubPush()
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/priyaaaa70/devopsProject', branch: 'main'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'python -m pip install -r requirements.txt'
            }
        }

        stage('Run Collector') {
            steps {
                bat 'python src/main/collector.py'
            }
        }

        stage('Run Metrics') {
            steps {
                bat 'python src/main/metrics.py'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}